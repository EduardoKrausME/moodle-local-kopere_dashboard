{{!
    @template koperedashboard_pages/settings
}}
<div class="kopere_dashboard-card kopere_dashboard-pages-form">
    <form method="post" action="{{{actionurl}}}">
        <input type="hidden" name="sesskey" value="{{{sesskey}}}">

        <div class="form-group">
            <label for="webpages_theme">{{#str}}field_default_theme, koperedashboard_pages{{/str}}</label>
            <select class="form-control" id="webpages_theme" name="webpages_theme">
                {{#themeoptions}}
                    <option value="{{{key}}}" {{#selected}}selected{{/selected}}>{{{value}}}</option>
                {{/themeoptions}}
            </select>
        </div>

        <div class="form-group">
            <label for="webpages_analytics_id">{{#str}}field_analytics, koperedashboard_pages{{/str}}</label>
            <textarea class="form-control" id="webpages_analytics_id" name="webpages_analytics_id"
                      rows="5">{{{analytics}}}</textarea>
            <small class="form-text text-muted">{{#str}}field_analytics_help, koperedashboard_pages{{/str}}</small>
        </div>

        <div class="kopere_dashboard-pages-form-actions">
            <button type="submit" class="btn btn-primary">{{#str}}savechanges{{/str}}</button>
            <a class="btn btn-outline-secondary" href="{{{cancelurl}}}">{{#str}}cancel{{/str}}</a>
        </div>
    </form>
</div>
