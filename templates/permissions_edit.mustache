{{!
    @template local_kopere_dashboard/permissions_edit

    Example context (json):
    {
        "name": "Manage payment plans",
        "description": "Allows users to create and manage recurring payment plans and student assignments.",
        "backurl": "https://moodle.example.com/local/kopere_dashboard/permissions.php",
        "formhtml": "<form method=\"post\" action=\"https://moodle.example.com/local/kopere_dashboard/permissions.php\"><button type=\"submit\" class=\"btn btn-primary\">Save changes</button></form>"
    }
}}

<div class="kopere_dashboard-card">
    <div style="display:flex; justify-content: space-between; align-items:center;">
        <div>
            <h5>{{{name}}}</h5>
            <div class="muted" style="margin-top: 6px;">{{{description}}}</div>
        </div>

        <div>
            <a class="btn btn-secondary" href="{{{backurl}}}">{{#str}}back, core{{/str}}</a>
        </div>
    </div>
</div>

<div style="margin-top: 16px;">
    {{{formhtml}}}
</div>
