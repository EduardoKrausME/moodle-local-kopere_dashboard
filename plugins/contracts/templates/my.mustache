{{!
    @template koperedashboard_contracts/my

    Example context (json):
    {
    }
}}

<div class="kopere_dashboard-card">
    <table class="table table-striped kopere_dashboard-card-table">
        <thead>
        <tr>
            <th>{{#str}}field_name, koperedashboard_contracts{{/str}}</th>
            <th>{{#str}}field_course, koperedashboard_contracts{{/str}}</th>
            <th>{{#str}}field_timeaccepted, koperedashboard_contracts{{/str}}</th>
            <th>{{#str}}field_readseconds, koperedashboard_contracts{{/str}}</th>
            <th></th>
        </tr>
        </thead>
        <tbody>
        {{#hasitems}}
            {{#items}}
                <tr>
                    <td>{{{contractname}}}</td>
                    <td>{{{coursename}}}</td>
                    <td>{{{timeaccepted}}}</td>
                    <td>{{{readseconds}}}</td>
                    <td class="text-nowrap">
                        <a class="btn btn-secondary" href="{{{pdfurl}}}" target="_blank">
                            {{#str}}opencontract, koperedashboard_contracts{{/str}}
                        </a>
                    </td>
                </tr>
            {{/items}}
        {{/hasitems}}
        {{^hasitems}}
            <tr>
                <td colspan="5">{{#str}}nocontracts, koperedashboard_contracts{{/str}}</td>
            </tr>
        {{/hasitems}}
        </tbody>
    </table>
</div>
