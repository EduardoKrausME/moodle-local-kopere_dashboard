{{!
    @template koperedashboard_attest/studentcard_settings

    Context variables:
    * formhtml: rendered Moodle form.
    * frontplaceholders: variables available in the front template.
    * backplaceholders: variables available in the back template.
}}

<div class="local-kopere_dashboard-grid">
    <div class="kopere_dashboard-card">
        <h2>{{#str}}studentcard_settings_title, koperedashboard_attest{{/str}}</h2>
        <p class="muted">{{#str}}studentcard_settings_description, koperedashboard_attest{{/str}}</p>

        {{{formhtml}}}

        <h3>{{#str}}studentcard_settings_front_variables, koperedashboard_attest{{/str}}</h3>
        <p class="muted">{{#str}}studentcard_settings_front_variables_desc, koperedashboard_attest{{/str}}</p>
        <table>
            {{#frontplaceholders}}
                <tr>
                    <td><code>{{key}}</code></td>
                    <td><strong>{{description}}</strong></td>
                </tr>
            {{/frontplaceholders}}
        </table>

        <h3>{{#str}}studentcard_settings_back_variables, koperedashboard_attest{{/str}}</h3>
        <p class="muted">{{#str}}studentcard_settings_back_variables_desc, koperedashboard_attest{{/str}}</p>
        <table>
            {{#backplaceholders}}
                <tr>
                    <td><code>{{key}}</code></td>
                    <td><strong>{{description}}</strong></td>
                </tr>
            {{/backplaceholders}}
        </table>
    </div>
</div>
