{{!
    @template koperedashboard_backup/index
}}

<div class="kopere_dashboard-card">
    <div class="alert alert-info" style="margin-bottom: 16px;">
        <strong>{{#str}}storage_title, koperedashboard_backup{{/str}}</strong><br>
        {{#str}}storage_desc, koperedashboard_backup{{/str}}<br>
        <code>{{{backupdir}}}</code>
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="border rounded p-3 h-100">
                <h4>{{{moodledata_title}}}</h4>
                <p class="text-muted">{{{moodledata_desc}}}</p>

                {{#cangenerate}}
                    <form method="post" action="">
                        <input type="hidden" name="sesskey" value="{{{sesskey}}}">
                        <input type="hidden" name="action" value="moodledata">
                        <button type="submit" class="btn btn-primary">
                            {{#str}}action_generate_moodledata, koperedashboard_backup{{/str}}
                        </button>
                    </form>
                {{/cangenerate}}
            </div>
        </div>

        <div class="col-md-6">
            <div class="border rounded p-3 h-100">
                <h4>{{{database_title}}}</h4>
                <p class="text-muted">{{{database_desc}}}</p>

                <div class="alert alert-light" style="margin-bottom: 16px;">
                    <strong>{{#str}}current_source_label, koperedashboard_backup{{/str}}</strong>
                    {{{sourcedblabel}}}
                </div>

                {{#cangenerate}}
                    <form method="post" action="">
                        <input type="hidden" name="sesskey" value="{{{sesskey}}}">
                        <input type="hidden" name="action" value="database">

                        <div class="form-group">
                            <label for="id_dbformat">{{#str}}outputformat_label, koperedashboard_backup{{/str}}</label>
                            <select id="id_dbformat" name="dbformat" class="custom-select form-control">
                                {{#formats}}
                                    <option value="{{{value}}}" {{#selected}}selected{{/selected}}>{{{label}}}</option>
                                {{/formats}}
                            </select>
                            <small class="form-text text-muted">{{#str}}
                                outputformat_desc, koperedashboard_backup{{/str}}</small>
                        </div>

                        <div class="form-group form-check" style="margin-top: 12px;">
                            <input
                                    type="checkbox"
                                    class="form-check-input"
                                    id="id_separatelogs"
                                    name="separatelogs"
                                    value="1"
                                    {{#separatelogs}}checked{{/separatelogs}}>
                            <label class="form-check-label" for="id_separatelogs">
                                {{#str}}separatelogs_label, koperedashboard_backup{{/str}}
                            </label>
                            <small class="form-text text-muted">{{#str}}
                                separatelogs_desc, koperedashboard_backup{{/str}}</small>
                        </div>

                        <button type="submit" class="btn btn-primary">
                            {{#str}}action_generate_database, koperedashboard_backup{{/str}}
                        </button>
                    </form>
                {{/cangenerate}}
            </div>
        </div>
    </div>
</div>

<div class="kopere_dashboard-card" style="margin-top: 16px;">
    <h4 style="margin-bottom: 16px;">{{#str}}history_title, koperedashboard_backup{{/str}}</h4>

    {{#hasfiles}}
        <table class="table table-striped kopere_dashboard-card-table">
            <thead>
            <tr>
                <th>{{#str}}col_type, koperedashboard_backup{{/str}}</th>
                <th>{{#str}}col_file, koperedashboard_backup{{/str}}</th>
                <th>{{#str}}col_size, koperedashboard_backup{{/str}}</th>
                <th>{{#str}}col_created, koperedashboard_backup{{/str}}</th>
                <th>{{#str}}col_actions, koperedashboard_backup{{/str}}</th>
            </tr>
            </thead>
            <tbody>
            {{#files}}
                <tr>
                    <td>{{{type_label}}}</td>
                    <td><code>{{{filename}}}</code></td>
                    <td>{{{size}}}</td>
                    <td>{{{timecreated}}}</td>
                    <td>
                        <a class="btn btn-secondary btn-sm" href="{{{downloadurl}}}">
                            {{#str}}action_download, koperedashboard_backup{{/str}}
                        </a>
                    </td>
                </tr>
            {{/files}}
            </tbody>
        </table>
    {{/hasfiles}}

    {{^hasfiles}}
        <div class="alert alert-light" style="margin-bottom: 0;">{{{emptyfiles}}}</div>
    {{/hasfiles}}
</div>
