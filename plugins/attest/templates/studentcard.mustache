{{!
    @template koperedashboard_attest/studentcard

    Example context (json):
    {
    }
}}

<div class="kopere_dashboard-card">
    {{#hasphoto}}
        <div class="mb-3">
            <div>{{{fullname}}}</div>
            <div>{{{email}}}</div>
            <div>CPF: {{{cpf}}}</div>
            <a href="{{{generateurl}}}" class="btn btn-primary mt-4" target="_blank">
                {{{generatelabel}}}
            </a>
        </div>
    {{/hasphoto}}

    {{^hasphoto}}
        <div class="alert alert-danger" role="alert">
            {{{message}}}
        </div>

        <div class="mb-3">
            <a href="{{{editurl}}}" class="btn btn-primary" target="_blank">
                {{{editlabel}}}
            </a>
        </div>
    {{/hasphoto}}
</div>
