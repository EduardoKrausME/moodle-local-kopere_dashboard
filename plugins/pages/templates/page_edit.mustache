{{!
    @template koperedashboard_pages/page_edit

    Example context (json):
    {
        "actionurl": "http://moodlesite/..."
    }
}}

{{!
    @template koperedashboard_pages/page_edit
}}
<div class="kopere_dashboard-card kopere_dashboard-pages-form">
    {{#haserror}}
        <div class="alert alert-danger">{{{error}}}</div>
    {{/haserror}}

    <form method="post" action="{{{actionurl}}}">
        <input type="hidden" name="sesskey" value="{{{sesskey}}}">
        <input type="hidden" id="id" name="id" value="{{{id}}}">

        <div class="form-group">
            <label for="title">{{#str}}field_title, koperedashboard_pages{{/str}}</label>
            <input type="text" class="form-control" id="title" name="title" value="{{{title}}}" required>
        </div>

        <div class="form-group">
            <label for="link">{{#str}}field_link, koperedashboard_pages{{/str}}</label>
            <input type="text" class="form-control" id="link" name="link" value="{{{link}}}" required>
            <small class="form-text text-muted">{{#str}}field_link_help, koperedashboard_pages{{/str}}</small>
        </div>

        <div class="row">
            <div class="col-md-4">
                <div class="form-group">
                    <label for="menuid">{{#str}}field_menu, koperedashboard_pages{{/str}}</label>
                    <select class="form-control" id="menuid" name="menuid">
                        {{#menuoptions}}
                            <option value="{{{key}}}" {{#selected}}selected{{/selected}}>{{{value}}}</option>
                        {{/menuoptions}}
                    </select>
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group">
                    <label for="courseid">{{#str}}field_course, koperedashboard_pages{{/str}}</label>
                    <select class="form-control" id="courseid" name="courseid">
                        {{#courseoptions}}
                            <option value="{{{key}}}" {{#selected}}selected{{/selected}}>{{{value}}}</option>
                        {{/courseoptions}}
                    </select>
                </div>
            </div>
            <div class="col-md-4">
                <div class="form-group">
                    <label for="theme">{{#str}}field_theme, koperedashboard_pages{{/str}}</label>
                    <select class="form-control" id="theme" name="theme">
                        {{#themeoptions}}
                            <option value="{{{key}}}" {{#selected}}selected{{/selected}}>{{{value}}}</option>
                        {{/themeoptions}}
                    </select>
                </div>
            </div>
        </div>

        <div class="form-check mb-3">
            <input type="checkbox" class="form-check-input" id="visible" name="visible" value="1"
                   {{#visible}}checked{{/visible}}>
            <label class="form-check-label" for="visible">{{#str}}field_visible, koperedashboard_pages{{/str}}</label>
        </div>

        {{#pageedit_url}}
            <div class="form-group">
                <a class="btn btn-info" target="editor" href="{{{pageedit_url}}}">
                    {{#str}}webpages_edit, koperedashboard_pages{{/str}}
                </a>
                <p><small class="form-text text-muted">{{#str}}field_text_help, koperedashboard_pages{{/str}}</small></p>
            </div>
        {{/pageedit_url}}
        {{^pageedit_url}}
            <div class="alert alert-info">
                <i class="fa fa-info-circle"></i>
                {{#str}}webpages_firstsave, koperedashboard_pages{{/str}}
            </div>
        {{/pageedit_url}}

        <div class="kopere_dashboard-pages-form-actions">
            <button type="submit" class="btn btn-primary">{{#str}}savechanges{{/str}}</button>
            <a class="btn btn-outline-secondary" href="{{{cancelurl}}}">{{#str}}cancel{{/str}}</a>
        </div>
    </form>
</div>
